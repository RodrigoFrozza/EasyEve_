generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  accountCode   String?      @unique
  email         String?
  name          String?
  characters    Character[]
  fits          Fit[]
  activities    Activity[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Character {
  id              Int       @id
  name            String
  ownerHash       String    @unique
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  
  totalSp         Int       @default(0)
  walletBalance   Float     @default(0)
  location        String?
  ship            String?
  shipTypeId      Int?
  
  isMain          Boolean   @default(false)
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  lastFetchedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model Fit {
  id          String   @id @default(cuid())
  name        String
  shipTypeId  Int
  shipName    String
  modules     Json     @default("[]")
  dps        Int?
  tank       Int?
  cost       Float?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}



model Activity {
  id           String   @id @default(cuid())
  userId       String
  
  type         String   // mining, ratting, abyssal, exploration, crab, escalations, pvp
  name         String?
  
  // Common fields
  region       String?  // Minmatar, Gallente, etc
  space        String?  // highsec, lowsec, nullsec, wormhole
  
  // Mining specific
  miningType   String?  // ore, ice, gas
  
  // Ratting specific
  npcFaction   String?  // Angel Cartel, Blood Raider, etc
  siteName     String?  // Forsaken Hub, Haven, etc
  siteType     String?  // Belt, Anomaly, Signature, DED
  
  // Abyssal specific
  tier         String?  // T0-T6
  weather      String?  // Electrical, Dark, Exotic, Firestorm, Gamma
  shipSize     String?  // frigate, destroyer, cruiser
  
  // Exploration specific
  explorationSiteType String? // Relic, Data, Ghost, Gas, Sleeper
  difficulty   String?  // I, II, III, IV, V
  
  // Escalations specific
  dedLevel     String?  // 1/10 to 10/10
  escalationFaction String? // Angel, Blood Raider, etc
  
  // Crab specific
  crabPhase    String?  // Deployment, Linking, Scanning, Rewards
  
  // PVP specific
  pvpType      String?  // Ganking, Small Gang, Fleet, Solo
  
  fit          String?  // Optional - free text
  
  status       String   @default("active") // active, completed
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  
  participants Json     @default("[]") // [{"characterId": 123, "fit": "optional"}]
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

model SdeCache {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([expiresAt])
}

model FilamentType {
  id          Int      @id
  name        String
  weather     String
  tier        Int
  effect      String
  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("filament_types")
}

model OreType {
  id          Int      @id
  name        String
  groupName   String
  volume      Float?
  basePrice   Float?
  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("ore_types")
}

model ExplorationSiteType {
  id          Int      @id
  name        String
  category    String
  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("exploration_site_types")
}
